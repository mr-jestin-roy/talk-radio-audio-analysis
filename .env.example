# ── LLM Backend ───────────────────────────────────────────────────────────────

# Option 1 — Google Gemini Flash (free tier, recommended for Azure):
LLM_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_MODEL=gemini-2.0-flash
LLM_API_KEY=AIza...   # get from https://aistudio.google.com/apikey

# Option 2 — Local vllm via ngrok (PhD server GPU):
# LLM_URL=https://xxxx.ngrok-free.app
# LLM_MODEL=Qwen/Qwen3-8B-AWQ
# LLM_API_KEY=dummy

# Option 3 — Azure OpenAI (paid fallback):
# LLM_URL=https://YOUR-RESOURCE.openai.azure.com/openai/deployments/gpt-4o-mini
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=your-azure-openai-key

# ── Vector DB (Weaviate) ───────────────────────────────────────────────────────

# Local Docker (default):
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=

# Azure Container Apps (set by deploy.sh automatically):
# WEAVIATE_URL=http://talk-radio-weaviate.internal.azurecontainerapps.io
# WEAVIATE_API_KEY=

# ── Data paths (Azure mounts these at /app/data/…) ───────────────────────────
# TRANSCRIPTS_DIR=/app/data/transcripts
# RESULTS_DIR=/app/data/results
