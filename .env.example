# ── LLM Backend ───────────────────────────────────────────────────────────────
# Local vllm via ngrok:
LLM_URL=https://xxxx-xx.ngrok-free.app
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
LLM_API_KEY=dummy

# Azure OpenAI (swap in for production):
# LLM_URL=https://YOUR-RESOURCE.openai.azure.com/openai/deployments/gpt-4o-mini
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=your-azure-openai-key

# ── Weaviate ───────────────────────────────────────────────────────────────────
# Local Docker (default, no key needed):
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=

# Weaviate Cloud (production):
# WEAVIATE_URL=https://YOUR-CLUSTER.weaviate.network
# WEAVIATE_API_KEY=your-weaviate-api-key
